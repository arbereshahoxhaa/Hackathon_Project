# Copy this to .env and fill in your values before running
# cp .env.example .env   (Mac/Linux)
# copy .env.example .env  (Windows)

# ── Required ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#data-alerts

# ── Service URLs (defaults work for local dev — only change for remote) ────
LOG_COLLECTOR_URL=http://localhost:8001
DIAGNOSIS_URL=http://localhost:8002
OWNERSHIP_URL=http://localhost:8003
NOTIFICATION_URL=http://localhost:8004
